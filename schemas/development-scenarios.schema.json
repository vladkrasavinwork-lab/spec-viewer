{
  "$schema": "https://json-schema.org/draft/2020-12/schema", "type": "object", "additionalProperties": false,
  "required": ["schema_version", "run_id", "scenarios"], "properties": {
    "schema_version": {"const": "1.0"}, "run_id": {"type": "string", "pattern": "^[0-9]{8}T[0-9]{6}Z-estimate$"},
    "scenarios": {"type": "array", "minItems": 2, "items": {"type": "object", "additionalProperties": false, "required": ["id", "name", "description", "team", "calendar_weeks", "included_work_ids", "exclusions"], "properties": {
      "id": {"type": "string", "pattern": "^DEV-[0-9]{3,}$"}, "name": {"type": "string", "minLength": 1}, "description": {"type": "string", "minLength": 1}, "team": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}}, "calendar_weeks": {"type": "object", "additionalProperties": false, "required": ["optimistic", "expected", "conservative"], "properties": {"optimistic": {"type": "number", "minimum": 0}, "expected": {"type": "number", "minimum": 0}, "conservative": {"type": "number", "minimum": 0}}}, "included_work_ids": {"type": "array", "items": {"type": "string", "pattern": "^WORK-[0-9]{3,}$"}}, "exclusions": {"type": "array", "items": {"type": "string", "minLength": 1}}
    }}}
  }
}
