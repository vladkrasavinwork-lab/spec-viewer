{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object", "additionalProperties": false,
  "required": ["schema_version", "run_id", "selected_level", "currency", "levels"],
  "properties": {
    "schema_version": {"const": "1.0"},
    "run_id": {"type": "string", "pattern": "^[0-9]{8}T[0-9]{6}Z-estimate$"},
    "selected_level": {"type": ["string", "null"], "enum": ["light", "standard", "critical", null]},
    "currency": {"type": ["string", "null"]},
    "rates_profile_id": {"type": ["string", "null"]},
    "levels": {
      "type": "array", "minItems": 3,
      "items": {
        "type": "object", "additionalProperties": false,
        "required": ["name", "coverage", "engineering_hours_range", "engineering_cost_range", "infrastructure_excluded", "formula"],
        "properties": {
          "name": {"enum": ["light", "standard", "critical"]},
          "coverage": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
          "engineering_hours_range": {"$ref": "#/$defs/range"},
          "engineering_cost_range": {"anyOf": [{"$ref": "#/$defs/range"}, {"type": "null"}]},
          "infrastructure_excluded": {"const": true},
          "formula": {"type": "string", "minLength": 1}
        }
      }
    }
  },
  "$defs": {
    "range": {
      "type": "object", "additionalProperties": false,
      "required": ["minimum", "expected", "maximum"],
      "properties": {
        "minimum": {"type": "number", "minimum": 0},
        "expected": {"type": "number", "minimum": 0},
        "maximum": {"type": "number", "minimum": 0}
      }
    }
  }
}
