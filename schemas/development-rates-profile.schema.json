{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object", "additionalProperties": false,
  "required": ["schema_version", "profile_id", "currency", "region", "retrieved_at", "valid_until", "cost_basis", "methodology", "blended_hourly_rate", "rates"],
  "properties": {
    "schema_version": {"const": "1.0"},
    "profile_id": {"type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"},
    "currency": {"type": "string", "pattern": "^[A-Z]{3}$"},
    "region": {"type": "string", "minLength": 1},
    "retrieved_at": {"type": "string", "format": "date"},
    "valid_until": {"type": "string", "format": "date"},
    "cost_basis": {"enum": ["loaded_internal_cost", "billable_rate"]},
    "methodology": {
      "type": "object", "additionalProperties": false,
      "required": ["salary_source_url", "salary_source_note", "employer_load_factor", "productive_hours_per_month", "calculation"],
      "properties": {
        "salary_source_url": {"type": "string", "format": "uri"},
        "salary_source_note": {"type": "string", "minLength": 1},
        "employer_load_factor": {"type": "number", "minimum": 1},
        "productive_hours_per_month": {"type": "number", "exclusiveMinimum": 0},
        "calculation": {"type": "string", "minLength": 1}
      }
    },
    "blended_hourly_rate": {"type": "number", "exclusiveMinimum": 0},
    "rates": {
      "type": "array", "minItems": 1,
      "items": {
        "type": "object", "additionalProperties": false,
        "required": ["discipline", "level", "monthly_salary_reference", "hourly_rate", "confidence"],
        "properties": {
          "discipline": {"type": "string", "pattern": "^[a-z][a-z0-9_]*$"},
          "level": {"enum": ["middle", "senior", "lead"]},
          "monthly_salary_reference": {"type": "number", "minimum": 0},
          "hourly_rate": {"type": "number", "exclusiveMinimum": 0},
          "confidence": {"enum": ["low", "medium", "high"]}
        }
      }
    }
  }
}
