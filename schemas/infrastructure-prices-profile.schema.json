{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object", "additionalProperties": false,
  "required": ["schema_version", "profile_id", "provider", "region", "currency", "includes_tax", "retrieved_at", "valid_until", "prices"],
  "properties": {
    "schema_version": {"const": "1.0"},
    "profile_id": {"type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"},
    "provider": {"type": "string", "minLength": 1},
    "region": {"type": "string", "minLength": 1},
    "currency": {"type": "string", "pattern": "^[A-Z]{3}$"},
    "includes_tax": {"type": "boolean"},
    "retrieved_at": {"type": "string", "format": "date"},
    "valid_until": {"type": "string", "format": "date"},
    "prices": {
      "type": "array", "minItems": 1,
      "items": {
        "type": "object", "additionalProperties": false,
        "required": ["id", "category", "description", "unit", "unit_price", "source_url", "source_date"],
        "properties": {
          "id": {"type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"},
          "category": {"type": "string", "minLength": 1},
          "description": {"type": "string", "minLength": 1},
          "unit": {"type": "string", "minLength": 1},
          "unit_price": {"type": "number", "minimum": 0},
          "source_url": {"type": "string", "format": "uri"},
          "source_date": {"type": "string", "format": "date"}
        }
      }
    }
  }
}
