{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object", "additionalProperties": false,
  "required": ["schema_version", "profile_id", "currency", "retrieved_at", "valid_until", "subscriptions"],
  "properties": {
    "schema_version": {"const": "1.0"},
    "profile_id": {"type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"},
    "currency": {"type": "string", "pattern": "^[A-Z]{3}$"},
    "retrieved_at": {"type": "string", "format": "date"},
    "valid_until": {"type": "string", "format": "date"},
    "subscriptions": {
      "type": "array", "minItems": 1,
      "items": {
        "type": "object", "additionalProperties": false,
        "required": ["id", "product", "plan", "billing_unit", "unit_price", "default_quantity", "selected", "source_url", "source_date"],
        "properties": {
          "id": {"type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"},
          "product": {"type": "string", "minLength": 1},
          "plan": {"type": "string", "minLength": 1},
          "billing_unit": {"enum": ["user_month", "workspace_month", "usage_month"]},
          "unit_price": {"type": "number", "minimum": 0},
          "default_quantity": {"type": "number", "minimum": 0},
          "selected": {"type": "boolean"},
          "source_url": {"type": "string", "format": "uri"},
          "source_date": {"type": "string", "format": "date"}
        }
      }
    }
  }
}
