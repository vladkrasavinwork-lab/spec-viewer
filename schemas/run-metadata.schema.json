{
  "$schema": "https://json-schema.org/draft/2020-12/schema", "type": "object", "additionalProperties": false,
  "required": ["schema_version", "run_id", "project_id", "skill_name", "skill_version", "methodology_version", "input_hashes", "generated_at", "status", "confidence", "error"],
  "properties": {
    "schema_version": {"const": "1.0"}, "run_id": {"type": "string", "pattern": "^[0-9]{8}T[0-9]{6}Z-(review|rewrite|estimate)$"},
    "project_id": {"type": "string", "pattern": "^PRJ-[A-Z0-9]{8,32}$"}, "skill_name": {"enum": ["product-spec-review", "product-spec-rewrite", "product-delivery-estimate"]},
    "skill_version": {"type": "string", "minLength": 1}, "methodology_version": {"type": "string", "minLength": 1},
    "input_hashes": {"type": "object", "additionalProperties": {"type": "string", "pattern": "^[a-fA-F0-9]{64}$"}},
    "generated_at": {"type": "string", "format": "date-time"}, "status": {"enum": ["pending", "running", "completed", "partial", "blocked", "failed"]},
    "confidence": {"type": ["string", "null"], "enum": ["low", "medium", "high", null]},
    "error": {"anyOf": [{"type": "null"}, {"type": "object", "additionalProperties": false, "required": ["code", "message"], "properties": {"code": {"type": "string"}, "message": {"type": "string"}}}]}
  },
  "allOf": [{"if": {"properties": {"status": {"enum": ["partial", "failed"]}}}, "then": {"properties": {"error": {"type": "object"}}}}]
}
